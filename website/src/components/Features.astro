---
// website/src/components/Features.astro
const features = [
  {
    title: 'Auto-discovery',
    description: 'Detects all running Claude Code sessions by scanning processes at the OS level. No plugins, no setup.',
    image: '/screenshots/monitor-tab.png',
  },
  {
    title: 'Real-time status',
    description: 'See at a glance which sessions are Working, Need Permission, or Idle. Permission requests surface first.',
    image: '/screenshots/monitor-tab.png',
  },
  {
    title: 'Session history',
    description: 'Browse and search all past sessions with instant metadata filter and deep content search.',
    image: '/screenshots/history-tab.png',
  },
  {
    title: 'Cost tracker',
    description: 'Daily, per-project, and per-model spending breakdowns across all your Claude Code sessions.',
    image: '/screenshots/cost-tab.png',
  },
  {
    title: 'Tray popover',
    description: 'Click the menu bar icon for a quick-glance overlay with session status directly from the menu bar.',
    image: '/screenshots/tray-popover.jpeg',
  },
  {
    title: 'Conversation viewer',
    description: 'Expand any session to see the full conversation with formatted markdown, code blocks, and inline images.',
    image: '/screenshots/conversation-viewer.png',
  },
];
---

<section class="features">
  <h2 class="features-heading">Features</h2>
  <div class="features-grid">
    {features.map(f => (
      <div class="feature-card">
        <h3 class="feature-title">{f.title}</h3>
        <p class="feature-desc">{f.description}</p>
        <div class="feature-img">
          <img src={f.image} alt={f.title} loading="lazy" />
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .features {
    padding: 4rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
    border-top: 1px solid var(--border-muted);
  }

  .features-heading {
    text-align: center;
    font-size: 1.75rem;
    margin-bottom: 3rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    padding: 1.5rem;
    transition: border-color var(--transition-fast);
  }

  .feature-card:hover {
    border-color: var(--border-focus);
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .feature-desc {
    color: var(--text-secondary);
    font-size: 14px;
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }

  .feature-img {
    border: 1px solid var(--border-muted);
    overflow: hidden;
  }

  .feature-img img {
    width: 100%;
    display: block;
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
