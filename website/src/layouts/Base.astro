---
// website/src/layouts/Base.astro
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
}

const { title, description = 'Monitor and control all your Claude Code sessions from one place.', hideNav = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/icon.png" />
</head>
<body>
  {!hideNav && <Nav />}
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
