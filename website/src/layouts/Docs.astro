---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import DocsSidebar from '../components/DocsSidebar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Base title={`${title} — c9watch`} hideNav>
  <Nav />
  <div class="docs-wrapper">
    <DocsSidebar currentPath={currentPath} />
    <main class="docs-content">
      <slot />
    </main>
  </div>
</Base>

<style>
  .docs-wrapper {
    display: flex;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2rem;
    min-height: calc(100vh - 56px);
  }

  .docs-content {
    flex: 1;
    padding: 2rem 0 4rem 2rem;
    max-width: 700px;
  }

  .docs-content :global(h1) {
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  .docs-content :global(h2) {
    font-size: 1.35rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-muted);
  }

  .docs-content :global(h3) {
    font-size: 1.1rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .docs-content :global(p) {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .docs-content :global(code) {
    background: var(--bg-card);
    padding: 0.15rem 0.4rem;
    font-size: 0.875em;
  }

  .docs-content :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .docs-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .docs-content :global(ul), .docs-content :global(ol) {
    color: var(--text-secondary);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .docs-content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.6;
  }

  .docs-content :global(img) {
    border: 1px solid var(--border-default);
    margin: 1rem 0;
  }

  @media (max-width: 768px) {
    .docs-wrapper {
      padding: 0 1rem;
    }

    .docs-content {
      padding-left: 0;
    }
  }
</style>
